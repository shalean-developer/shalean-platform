# --- Required on Vercel (Production) for slot lock / checkout signatures ---
# Without this, POST /api/booking/lock returns 503 and time slots cannot be confirmed.
# Generate: openssl rand -hex 32
BOOKING_LOCK_HMAC_SECRET=

# --- Server-side Supabase (API routes: catalog, time-slots, lock, etc.) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Twilio SMS (dispatch offer links; server-only) ---
# TWILIO_PHONE_NUMBER=E.164 sender (preferred). Alias: TWILIO_FROM_NUMBER (used by legacy SMS fallback).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_FROM_NUMBER=
# Optional: override public link host in SMS (default: NEXT_PUBLIC_APP_URL, else www.shalean.com in production)
# OFFER_SMS_BASE_URL=https://www.shalean.com

# --- Meta WhatsApp Cloud API (server-only) ---
# Required for outbound sends (throws "WhatsApp not configured" if missing):
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional: WhatsApp Business Account ID (dashboard reference; some ops scripts may read it)
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Legacy alias — prefer WHATSAPP_ACCESS_TOKEN; not used for outbound if ACCESS is unset
WHATSAPP_API_TOKEN=
# Graph version for https://graph.facebook.com/{version}/{phone-number-id}/messages (default v19.0)
# WHATSAPP_GRAPH_API_VERSION=v19.0
# Phase 8B — Meta template *names* (optional overrides; defaults match keys below). Variable counts are fixed in code.
# WHATSAPP_TEMPLATE_BOOKING_OFFER=booking_offer
#   5 body params: name, location, date, time, pay — Meta static copy should include reply instructions (see DB template reference).
# WHATSAPP_TEMPLATE_BOOKING_ASSIGNED=booking_assigned
#   3 body params: location, date, time
# WHATSAPP_TEMPLATE_REMINDER=reminder
#   2 body params: location, time
# WHATSAPP_TEMPLATE_OFFER_ACK, WHATSAPP_TEMPLATE_CLEANER_WELCOME, WHATSAPP_TEMPLATE_CLEANER_APPROVED (single {{1}} body var)
# Legacy Meta name aliases: WHATSAPP_CLEANER_JOB_OFFER_TEMPLATE, WHATSAPP_CLEANER_JOB_ASSIGNED_TEMPLATE
# Per-template languages: WHATSAPP_CLEANER_JOB_OFFER_LANG, WHATSAPP_TEMPLATE_BOOKING_OFFER_LANG, WHATSAPP_TEMPLATE_BOOKING_ASSIGNED_LANG, WHATSAPP_CLEANER_JOB_ASSIGNED_LANG, WHATSAPP_TEMPLATE_REMINDER_LANG
WHATSAPP_TEMPLATE_LANGUAGE=en
# Meta → WhatsApp → Configuration → Webhook: Verify token (GET hub.verify_token must match)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App Secret from Meta app — required in production: verifies POST /api/webhooks/whatsapp (X-Hub-Signature-256)
WHATSAPP_APP_SECRET=
# Optional: approved template name with a single {{1}} body variable — used when plain text fails (e.g. outside 24h)
WHATSAPP_FALLBACK_TEMPLATE_NAME=
WHATSAPP_FALLBACK_TEMPLATE_LANG=en
# Bearer secret for POST /api/test/whatsapp-send (queue + flush smoke test). Do not set in production unless needed.
# WHATSAPP_TEST_SEND_SECRET=

# --- Vercel Cron (POST + Authorization: Bearer CRON_SECRET) ---
# CRON_SECRET=
# GET/POST /api/cron/retry-failed-jobs — every minute on Vercel (see apps/web/vercel.json): dispatch_retry_queue, failed_jobs, SLA hooks
# GET/POST /api/cron/dispatch-timeouts — offer TTL expiry → delayed reassignment via dispatch_retry_queue
# Max total dispatch_offers rows per booking before auto-dispatch stops (default 5 → stop when count > 5; manual ops / unassignable)
# DISPATCH_MAX_OFFERS_PER_BOOKING=5
# Fixed delay in seconds before reassignment (default: random 30–60s when unset)
# DISPATCH_EXPIRED_REASSIGN_DELAY_SECONDS=45
# Backoff after a failed retry-queue assign: delay_seconds = base × (retries_done + 1); default base 30 → 30s, 60s, 90s… (cap 15m)
# DISPATCH_RETRY_BACKOFF_BASE_SECONDS=30
# Slack / ops webhook for dispatch escalation (see lib/dispatch/dispatchEscalation.ts)
# DISPATCH_ADMIN_WEBHOOK_URL=
# DISPATCH_ALERT_WEBHOOK_CRITICAL_URL=
# Schedule POST /api/cron/whatsapp-worker every 15–60s to drain whatsapp_queue (backoff via next_attempt_at).
# Optional: base delay in seconds for 2^n backoff between retries (default 60 → 1m, 2m, 4m, …)
# WHATSAPP_QUEUE_RETRY_BASE_SEC=60

# --- Admin payment link (POST /api/admin/bookings/with-payment) ---
# TTL for payment_link_expires_at when stored after Paystack initialize (default 60, min 5, max 10080 = 7d)
# ADMIN_PAYMENT_LINK_EXPIRES_MINUTES=60
# Min seconds between resend / notification batches for the same booking (default 120)
# PAYMENT_LINK_SEND_COOLDOWN_SECONDS=120

# --- Payment link automation (Vercel Cron + CRON_SECRET) ---
# POST /api/cron/expire-pending-payments — daily/hourly: status → payment_expired after payment_link_expires_at
# --- Phase 5: AI autonomy layer (wraps rules; master switch + per-domain) ---
# AI_DISABLED=true disables all autonomy features regardless of per-domain flags.
# AI_DISABLED=
# AI_PRICING_ENABLED=true
# AI_ASSIGNMENT_ENABLED=true
# AI_GROWTH_ENABLED=true

# POST /api/cron/payment-link-reminders — every ~15m: ~1h and ~15m before expiry, WhatsApp → SMS (no email)
