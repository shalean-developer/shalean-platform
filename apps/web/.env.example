# --- Required on Vercel (Production) for slot lock / checkout signatures ---
# Without this, POST /api/booking/lock returns 503 and time slots cannot be confirmed.
# Generate: openssl rand -hex 32
BOOKING_LOCK_HMAC_SECRET=

# --- Server-side Supabase (API routes: catalog, time-slots, lock, etc.) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Meta WhatsApp Cloud API (server-only) ---
# Bearer: set at least ONE of these (same permanent token from Meta → WhatsApp → API setup)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Graph version for https://graph.facebook.com/{version}/{phone-number-id}/messages (default v22.0)
# WHATSAPP_GRAPH_API_VERSION=v22.0
# Cleaner assignment: {{1}}–{{4}} as above; {{5}} = first segment of booking.location (≤60 chars). In Meta use body text `Location: {{5}}` (not bare {{5}}). Enable with WHATSAPP_CLEANER_JOB_INCLUDE_LOCATION=1 after template is re-approved.
# WHATSAPP_CLEANER_JOB_ASSIGNED_TEMPLATE=cleaner_job_assigned
# WHATSAPP_CLEANER_JOB_ASSIGNED_LANG=en
# WHATSAPP_CLEANER_JOB_INCLUDE_LOCATION=1
# Dispatch offer (first outbound to cleaner on offer): Meta template body {{1}} cleaner, {{2}} service, {{3}} date, {{4}} time, {{5}} location. Accept/decline buttons live in the template (Meta).
# WHATSAPP_CLEANER_JOB_OFFER_TEMPLATE=cleaner_job_offer
# WHATSAPP_CLEANER_JOB_OFFER_LANG=en
# Approved template for customer text fallback after session errors (body {{1}}–{{4}}: name, service, date, time)
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en
# Optional: default v22.0 — set e.g. v19.0 if your Meta app pins an older Graph version
# WHATSAPP_GRAPH_API_VERSION=v22.0
# Meta → WhatsApp → Configuration → Webhook: Verify token (GET hub.verify_token must match)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App Secret from Meta app — required in production: verifies POST /api/webhooks/whatsapp (X-Hub-Signature-256)
WHATSAPP_APP_SECRET=
# Optional: approved template name with a single {{1}} body variable — used when plain text fails (e.g. outside 24h)
WHATSAPP_FALLBACK_TEMPLATE_NAME=
WHATSAPP_FALLBACK_TEMPLATE_LANG=en
# Set true only in local/staging to log outbound instead of calling Meta
WHATSAPP_DEV_MODE=false
# Bearer secret for POST /api/test/whatsapp-send (queue + flush smoke test). Do not set in production unless needed.
# WHATSAPP_TEST_SEND_SECRET=

# --- Vercel Cron (POST + Authorization: Bearer CRON_SECRET) ---
# CRON_SECRET=
# Schedule POST /api/cron/whatsapp-worker every 15–60s to drain whatsapp_queue (backoff via next_attempt_at).
# Optional: base delay in seconds for 2^n backoff between retries (default 60 → 1m, 2m, 4m, …)
# WHATSAPP_QUEUE_RETRY_BASE_SEC=60

# --- Admin payment link (POST /api/admin/bookings/with-payment) ---
# TTL for payment_link_expires_at when stored after Paystack initialize (default 60, min 5, max 10080 = 7d)
# ADMIN_PAYMENT_LINK_EXPIRES_MINUTES=60
# Min seconds between resend / notification batches for the same booking (default 120)
# PAYMENT_LINK_SEND_COOLDOWN_SECONDS=120

# --- Payment link automation (Vercel Cron + CRON_SECRET) ---
# POST /api/cron/expire-pending-payments — daily/hourly: status → payment_expired after payment_link_expires_at
# --- Phase 5: AI autonomy layer (wraps rules; master switch + per-domain) ---
# AI_DISABLED=true disables all autonomy features regardless of per-domain flags.
# AI_DISABLED=
# AI_PRICING_ENABLED=true
# AI_ASSIGNMENT_ENABLED=true
# AI_GROWTH_ENABLED=true

# POST /api/cron/payment-link-reminders — every ~15m: ~1h and ~15m before expiry, WhatsApp → SMS (no email)
