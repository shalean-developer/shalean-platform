# { message, context, timestamp } (timestamp ISO). Slack/Discord/Zapier/pager; failures never break requests.
DISPATCH_ALERT_WEBHOOK_CRITICAL_URL=

# Optional: retry-failed-jobs cron deletes terminal failed_jobs rows older than 7 days only
# (types booking_insert_invalid_payload, booking_insert_exhausted). Prevents unbounded growth.
FAILED_JOBS_CLEANUP_ENABLED=false

