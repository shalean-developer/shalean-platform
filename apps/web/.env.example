# Copy to `.env.local` for local development. Never commit real secrets.
# `NODE_ENV` is set by Next.js — do not set it here unless you know you need to.

# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: non-public URL alias (admin client falls back to NEXT_PUBLIC_*)
SUPABASE_URL=
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Legacy alias read by lib/supabase/admin.ts
SUPABASE_SERVICE_KEY=

# =============================================================================
# App URLs (client + server)
# =============================================================================
NEXT_PUBLIC_APP_URL=
# SMS / offer links; defaults in dev
OFFER_SMS_BASE_URL=
NEXT_PUBLIC_SOCKET_IO_URL=
NEXT_PUBLIC_REVIEW_URL=

# =============================================================================
# Support & booking display (public)
# =============================================================================
NEXT_PUBLIC_SUPPORT_WHATSAPP=
NEXT_PUBLIC_SUPPORT_WHATSAPP_URL=
NEXT_PUBLIC_BOOKING_SERVICE_FEE_RULE=
NEXT_PUBLIC_BOOKING_SERVICE_FEE_CENTS=
# Optional booking schedule A/B (client-only): default pick strategy — score | cheapest | fastest_confirm
# NEXT_PUBLIC_SCHEDULE_AB_DEFAULT=
# Optional: initial slot row count before “See more” (4–12, default 7)
# NEXT_PUBLIC_SCHEDULE_VISIBLE_SLOTS=
BOOKING_SERVICE_FEE_RULE=
BOOKING_SERVICE_FEE_CENTS=

# =============================================================================
# Admin & dashboard auth
# =============================================================================
# Comma-separated admin emails (must match Supabase Auth user emails)
ADMIN_EMAILS=
# Single admin email fallback (see lib/auth/admin.ts)
ADMIN_EMAIL=
# Optional bearer for ops smoke script / tooling
ADMIN_SECRET=

# =============================================================================
# Secrets: cron, HMAC, test routes
# =============================================================================
CRON_SECRET=
BOOKING_LOCK_HMAC_SECRET=
EMAIL_TEST_SECRET=
WHATSAPP_TEST_SEND_SECRET=

# =============================================================================
# Email (Resend)
# =============================================================================
RESEND_API_KEY=
RESEND_FROM=

# =============================================================================
# Bookings financial snapshot (server)
# =============================================================================
# After migrations `20260805_bookings_customer_paid_at.sql` and `20260806_bookings_refund_tracking.sql`
# are applied, set to `1` so persist + repair SELECT includes `paid_at`, `refunded_at`, `refund_status`.
# Leave unset until then — avoids PostgREST errors if the app deploys before the DB.
# SHALEAN_BOOKINGS_FINANCIAL_SNAPSHOT_COLS=1

