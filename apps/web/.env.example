# --- Required on Vercel (Production) for slot lock / checkout signatures ---
# Without this, POST /api/booking/lock returns 503 and time slots cannot be confirmed.
# Generate: openssl rand -hex 32
BOOKING_LOCK_HMAC_SECRET=

# --- Server-side Supabase (API routes: catalog, time-slots, lock, etc.) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Meta WhatsApp Cloud API (server-only) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Bearer for POST-booking WhatsApp (lib/booking/triggerWhatsAppNotification — Graph v18.0). Can match WHATSAPP_API_TOKEN if you use one system user token.
WHATSAPP_ACCESS_TOKEN=
# Approved template for POST /api/bookings WhatsApp fallback (body must have {{1}}–{{4}}: name, service, date, time)
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en
# Optional: default v22.0 — set e.g. v19.0 if your Meta app pins an older Graph version
# WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_VERIFY_TOKEN=
# App Secret from Meta app — required in production: verifies POST /api/webhooks/whatsapp (X-Hub-Signature-256)
WHATSAPP_APP_SECRET=
# Optional: approved template name with a single {{1}} body variable — used when plain text fails (e.g. outside 24h)
WHATSAPP_FALLBACK_TEMPLATE_NAME=
WHATSAPP_FALLBACK_TEMPLATE_LANG=en
# Set true only in local/staging to log outbound instead of calling Meta
WHATSAPP_DEV_MODE=false
# Bearer secret for POST /api/test/whatsapp-send (queue + flush smoke test). Do not set in production unless needed.
# WHATSAPP_TEST_SEND_SECRET=

# --- Vercel Cron (POST + Authorization: Bearer CRON_SECRET) ---
# CRON_SECRET=
# Schedule POST /api/cron/whatsapp-worker every 15–60s to drain whatsapp_queue (backoff via next_attempt_at).
# Optional: base delay in seconds for 2^n backoff between retries (default 60 → 1m, 2m, 4m, …)
# WHATSAPP_QUEUE_RETRY_BASE_SEC=60
